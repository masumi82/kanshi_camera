# Required
UPLOAD_URL=https://example.com/api/v1/images
API_KEY=

# Optional
DEVICE_ID=kanshi-001
# Default capture interval in minutes (1-10). Overridable at runtime via the web UI.
CAPTURE_INTERVAL_MIN=1
MAX_RETRY_FILES=100
USTREAMER_HOST=127.0.0.1
USTREAMER_PORT=8080
# LAN IP shown to browsers for the MJPEG stream link (e.g. 192.168.1.100).
# Leave empty to derive from the HTTP Host header (suitable for private LAN).
USTREAMER_EXTERNAL_HOST=

# Web server (optional)
WEB_PORT=8888
# Bind address for the web server (default: 0.0.0.0 = all interfaces).
# On a private LAN this is fine; restrict to a specific IP if needed.
WEB_BIND=0.0.0.0
GALLERY_DIR=/var/lib/kanshi/gallery
# Retain roughly one month of frames. Hard count acts as a safety cap.
MAX_GALLERY_IMAGES=50000
MAX_GALLERY_DAYS=30
SETTINGS_FILE=/var/lib/kanshi/state/settings.json

# Stream authentication (optional)
STREAM_USER=
STREAM_PASSWORD=
